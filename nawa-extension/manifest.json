{
  "manifest_version": 3,
  "name": "Nawa Studio",
  "version": "2.0.0",
  "description": "Sourcez LinkedIn directement depuis votre navigateur — barre latérale intelligente",

  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "sidePanel"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://nawa-studio.vercel.app/*",
    "https://*.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_icon": {
      "16":  "icons/16.png",
      "48":  "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "Nawa Studio — Ouvrir"
  },

  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/results/people/*"],
      "js": ["content_linkedin_search.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content_linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://nawa-studio.vercel.app/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content_nawa.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16":  "icons/16.png",
    "48":  "icons/48.png",
    "128": "icons/128.png"
  }
}
